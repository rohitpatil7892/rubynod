{
  "name": "rubynod",
  "version": "0.1.0",
  "private": true,
  "description": "Rubynod — VS Code-class editor with Cursor-like AI",
  "repository": {
    "type": "git",
    "url": "https://github.com/rohitpatil7892/rubynod.git"
  },
  "bugs": {
    "url": "https://github.com/rohitpatil7892/rubynod/issues"
  },
  "homepage": "https://github.com/rohitpatil7892/rubynod#readme",
  "workspaces": [
    "packages/*",
    "extensions/*"
  ],
  "scripts": {
    "build": "npm run build -w @rubynod/shared -w @rubynod/index -w @rubynod/mcp -w @rubynod/ai -w @rubynod/cli -w rubynod-ai-ui",
    "build:all": "node scripts/build-all.mjs",
    "dev:ai": "npm run dev -w @rubynod/ai",
    "start:ai": "node scripts/run-ai.mjs",
    "dev:ext": "npm run watch -w rubynod-ai-ui",
    "setup:fork": "bash scripts/setup-code-oss-fork.sh",
    "setup:fork:win": "powershell -ExecutionPolicy Bypass -File scripts/setup-code-oss-fork.ps1",
    "test": "npm run test --workspaces --if-present",
    "cli": "node packages/rubynod-cli/dist/cli.js",
    "version:sync": "node scripts/sync-version.mjs",
    "release:manifests": "node scripts/generate-update-manifest.mjs",
    "package:ext": "npm run build -w rubynod-ai-ui && npx @vscode/vsce package extensions/rubynod-ai-ui --out dist/"
  },
  "engines": {
    "node": ">=20"
  }
}
