{
  "name": "rubynod-ai-ui",
  "displayName": "Rubynod AI",
  "description": "Cursor-like AI for Rubynod and VS Code",
  "version": "0.1.0",
  "publisher": "rubynod",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["AI", "Machine Learning"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rubynod-ai",
          "title": "Rubynod AI",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "rubynod-ai": [
        { "type": "webview", "id": "rubynod.chatView", "name": "Chat" }
      ]
    },
    "commands": [
      { "command": "rubynod.startAiService", "title": "Rubynod: Start AI Service" },
      { "command": "rubynod.clearChat", "title": "Rubynod: Clear Chat History" },
      { "command": "rubynod.openChat", "title": "Rubynod: Open Chat" },
      { "command": "rubynod.openComposer", "title": "Rubynod: Open Chat (Composer)" },
      { "command": "rubynod.openSettings", "title": "Rubynod: Open Settings" },
      { "command": "rubynod.inlineEdit", "title": "Rubynod: Inline Edit" },
      { "command": "rubynod.addFileToChat", "title": "Rubynod: Add File to Chat" },
      { "command": "rubynod.addToChat", "title": "Rubynod: Add to Chat" },
      { "command": "rubynod.addSelectionToChat", "title": "Rubynod: Add Selection to Chat" },
      { "command": "rubynod.addFolderToChat", "title": "Rubynod: Add Folder to Chat" },
      { "command": "rubynod.buildIndex", "title": "Rubynod: Build Codebase Index" },
      { "command": "rubynod.addMemory", "title": "Rubynod: Add Memory" },
      { "command": "rubynod.openGapAnalysis", "title": "Rubynod: Feature Gap vs Cursor/VS Code" },
      { "command": "rubynod.checkForUpdates", "title": "Rubynod: Check for Updates" },
      { "command": "rubynod.selectOllamaModel", "title": "Rubynod: Select Ollama Model" },
      { "command": "rubynod.acceptDiff", "title": "Rubynod: Accept Diff" },
      { "command": "rubynod.rejectDiff", "title": "Rubynod: Reject Diff" },
      { "command": "rubynod.undoCheckpoint", "title": "Rubynod: Undo Last Checkpoint" }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "rubynod.addToChat",
          "group": "navigation@99",
          "when": "!explorerResourceIsFolder"
        },
        {
          "command": "rubynod.addFolderToChat",
          "group": "navigation@99",
          "when": "explorerResourceIsFolder"
        }
      ],
      "editor/context": [
        {
          "command": "rubynod.addSelectionToChat",
          "group": "navigation@99",
          "when": "editorHasSelection"
        },
        {
          "command": "rubynod.addToChat",
          "group": "navigation@99",
          "when": "!editorHasSelection"
        }
      ]
    },
    "keybindings": [
      {
        "command": "rubynod.inlineEdit",
        "key": "ctrl+k",
        "mac": "cmd+k",
        "when": "editorTextFocus"
      },
      {
        "command": "rubynod.openChat",
        "key": "ctrl+l",
        "mac": "cmd+l"
      },
      {
        "command": "rubynod.openChat",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i"
      }
    ],
    "configuration": {
      "title": "Rubynod",
      "properties": {
        "rubynod.ai.serviceUrl": {
          "type": "string",
          "default": "http://127.0.0.1:3847",
          "description": "URL of the Rubynod AI agent service.",
          "order": 1
        },
        "rubynod.ai.repoPath": {
          "type": "string",
          "default": "",
          "description": "Path to your rubynod git clone (for Start AI Service). Auto-detected when the workspace is the rubynod repo.",
          "order": 2
        },

        "rubynod.models.provider": {
          "type": "string",
          "enum": ["openai", "anthropic", "ollama", "openrouter"],
          "default": "ollama",
          "description": "LLM provider (default: local Ollama).",
          "order": 10
        },
        "rubynod.models.chatModel": {
          "type": "string",
          "default": "llama3.2",
          "description": "Model for Chat and Agent (Cursor: default chat model).",
          "order": 11
        },
        "rubynod.models.tabModel": {
          "type": "string",
          "default": "",
          "description": "Model for Tab autocomplete. Empty = same as chat model.",
          "order": 12
        },
        "rubynod.models.inlineModel": {
          "type": "string",
          "default": "",
          "description": "Model for Cmd+K inline edit. Empty = same as chat model.",
          "order": 13
        },
        "rubynod.models.baseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:11434/v1",
          "description": "API base URL (Ollama OpenAI-compatible endpoint by default).",
          "order": 14
        },
        "rubynod.ollama.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "On startup, detect Ollama and select an installed local model automatically.",
          "order": 17
        },
        "rubynod.ollama.host": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "Ollama server URL (without /v1).",
          "order": 18
        },
        "rubynod.models.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "API key for the provider. Prefer env vars (`OPENAI_API_KEY`, `ANTHROPIC_API_KEY`) in shared machines. Cursor stores keys in your account; Rubynod uses local settings.",
          "order": 15
        },
        "rubynod.models.temperature": {
          "type": "number",
          "default": 0.2,
          "minimum": 0,
          "maximum": 2,
          "description": "Sampling temperature for chat/agent.",
          "order": 16
        },
        "rubynod.models.maxTokens": {
          "type": "number",
          "default": 8192,
          "minimum": 256,
          "maximum": 128000,
          "description": "Max tokens per model response.",
          "order": 17
        },

        "rubynod.chat.defaultMode": {
          "type": "string",
          "enum": ["agent", "plan", "ask", "debug"],
          "default": "agent",
          "enumDescriptions": [
            "Full agent: read/write files and terminal.",
            "Plan only: explore and write a plan, no edits.",
            "Ask only: Q&A without tools.",
            "Debug: focus on logs and reproduction."
          ],
          "description": "Default mode when opening Chat (Cursor: mode picker default).",
          "order": 20
        },
        "rubynod.chat.includeActiveFile": {
          "type": "boolean",
          "default": true,
          "description": "Attach the active editor file (and selection) to every message.",
          "order": 21
        },
        "rubynod.chat.includeOpenFiles": {
          "type": "boolean",
          "default": false,
          "description": "Also attach paths of all open editor tabs (lightweight list).",
          "order": 22
        },
        "rubynod.chat.maxFileContextChars": {
          "type": "number",
          "default": 48000,
          "description": "Max characters per attached file in chat context.",
          "order": 23
        },
        "rubynod.chat.maxContextAttachments": {
          "type": "number",
          "default": 20,
          "description": "Max @-attachments per message.",
          "order": 24
        },

        "rubynod.tab.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Tab ghost-text autocomplete (Cursor Tab).",
          "order": 30
        },
        "rubynod.tab.debounceMs": {
          "type": "number",
          "default": 600,
          "minimum": 100,
          "maximum": 3000,
          "description": "Delay before requesting a Tab completion.",
          "order": 31
        },
        "rubynod.tab.model": {
          "type": "string",
          "default": "",
          "description": "Override model for Tab only. Empty = rubynod.models.tabModel.",
          "order": 32
        },

        "rubynod.inline.model": {
          "type": "string",
          "default": "",
          "description": "Override model for Cmd+K inline edit.",
          "order": 35
        },

        "rubynod.agent.autoApproveTerminal": {
          "type": "boolean",
          "default": false,
          "description": "Run terminal commands without confirmation.",
          "order": 40
        },
        "rubynod.agent.autoApproveFileWrites": {
          "type": "boolean",
          "default": false,
          "description": "Apply agent file writes without showing diff first.",
          "order": 41
        },
        "rubynod.agent.yoloMode": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "**YOLO mode** (Cursor-style): auto-approve terminal + file writes. Use only in trusted repos.",
          "order": 42
        },
        "rubynod.agent.maxTurns": {
          "type": "number",
          "default": 25,
          "minimum": 1,
          "maximum": 100,
          "description": "Max tool-call loops per agent request.",
          "order": 43
        },

        "rubynod.index.autoIndexOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Build codebase index when workspace opens (@codebase).",
          "order": 50
        },
        "rubynod.index.autoIndexOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Update index when files are saved.",
          "order": 51
        },
        "rubynod.index.autoInjectContext": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "**Cursor-like:** Automatically attach relevant indexed code to every agent message (semantic search over your repo).",
          "order": 52
        },
        "rubynod.index.maxAutoContextChunks": {
          "type": "number",
          "default": 8,
          "description": "Max code chunks auto-injected per message.",
          "order": 53
        },
        "rubynod.index.maxAutoContextChars": {
          "type": "number",
          "default": 24000,
          "description": "Max characters of auto-injected index context.",
          "order": 54
        },

        "rubynod.performance.indexSaveDebounceMs": {
          "type": "number",
          "default": 800,
          "minimum": 200,
          "maximum": 5000,
          "description": "Debounce incremental index updates on save (ms).",
          "order": 55
        },
        "rubynod.performance.indexBuildConcurrency": {
          "type": "number",
          "default": 8,
          "minimum": 1,
          "maximum": 32,
          "description": "Parallel files during full index build.",
          "order": 56
        },
        "rubynod.performance.searchCandidateLimit": {
          "type": "number",
          "default": 400,
          "minimum": 50,
          "maximum": 2000,
          "description": "Max chunks considered per hybrid search query.",
          "order": 57
        },
        "rubynod.performance.contextCacheTtlSec": {
          "type": "number",
          "default": 45,
          "minimum": 0,
          "maximum": 600,
          "description": "Cache @codebase context packs per query (0 = off).",
          "order": 58
        },
        "rubynod.performance.statusPollIntervalMs": {
          "type": "number",
          "default": 30000,
          "minimum": 5000,
          "maximum": 120000,
          "description": "Index status bar refresh when idle (ms).",
          "order": 59
        },
        "rubynod.performance.folderContextMaxFiles": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 100,
          "description": "Max files included when attaching a folder.",
          "order": 60
        },

        "rubynod.tools.webSearch": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Enable **web_search** agent tool (DuckDuckGo). Requires network.",
          "order": 65
        },

        "rubynod.update.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Check GitHub for new Rubynod releases and show an update notification (like VS Code).",
          "order": 66
        },
        "rubynod.update.githubRepo": {
          "type": "string",
          "default": "rohitpatil7892/rubynod",
          "markdownDescription": "GitHub repo for releases (`owner/name`). Change to your fork after publishing.",
          "order": 67
        },
        "rubynod.update.checkIntervalHours": {
          "type": "number",
          "default": 12,
          "minimum": 1,
          "maximum": 168,
          "description": "How often to check for updates (hours).",
          "order": 68
        },

        "rubynod.privacy.privacyMode": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "**Privacy mode** (Cursor): avoid sending code to cloud embedders; prefer local index only.",
          "order": 60
        },
        "rubynod.privacy.localIndexOnly": {
          "type": "boolean",
          "default": true,
          "description": "Use local embeddings for @codebase (no cloud embedding API).",
          "order": 61
        },
        "rubynod.privacy.telemetry": {
          "type": "boolean",
          "default": false,
          "description": "Send anonymous usage telemetry (opt-in).",
          "order": 62
        },

        "rubynod.mcp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable MCP tool servers from ~/.rubynod/mcp.json.",
          "order": 70
        },

        "rubynod.ai.provider": {
          "type": "string",
          "deprecationMessage": "Use rubynod.models.provider instead.",
          "default": "openai"
        },
        "rubynod.ai.model": {
          "type": "string",
          "deprecationMessage": "Use rubynod.models.chatModel instead.",
          "default": "gpt-4o-mini"
        },
        "rubynod.ai.tabAutocomplete": {
          "type": "boolean",
          "deprecationMessage": "Use rubynod.tab.enabled instead.",
          "default": true
        },
        "rubynod.ai.autoApproveTerminal": {
          "type": "boolean",
          "deprecationMessage": "Use rubynod.agent.autoApproveTerminal instead.",
          "default": false
        },
        "rubynod.ai.includeActiveFile": {
          "type": "boolean",
          "deprecationMessage": "Use rubynod.chat.includeActiveFile instead.",
          "default": true
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.7.2"
  }
}
